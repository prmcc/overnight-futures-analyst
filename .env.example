# === REQUIRED: LLM (via OpenRouter) ===
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# === REQUIRED: Charts ===
# Get from https://chart-img.com (sign up for API key)
CHARTIMG_API_KEY=

# === TELEGRAM (primary delivery) ===
# 1. Message @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the bot token here
TELEGRAM_BOT_TOKEN=
# 3. Message your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Find your chat_id in the response JSON
TELEGRAM_CHAT_ID=

# === EMAIL (SMTP delivery) ===
# Any SMTP provider works (Hostinger, Gmail, etc.)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Comma-separated list of recipient emails
EMAIL_RECIPIENTS=

# === SCHEDULING ===
# Run `crontab -e` on your VPS and add this line:
# 30 5 * * 1-5 cd /path/to/overnight-futures-analyst && TZ=America/Los_Angeles npx tsx run.ts >> logs/cron.log 2>&1
#
# Or run manually: npm start
